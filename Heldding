public class HELD
{
    private int alter;
    private String vorname;
    private double groesse;
    private boolean rechtshaender;
    private char initial;
    
    public HELD()
    {
        alter = 38;
        vorname = "wwowowo";
        groesse = 1.84;
        rechtshaender = true;
        initial = 'W';
    }
    
    public HELD(String vorname, int alter, boolean rechtshaender, double groesse, char initial)
    {
        this.vorname = vorname;
        this.alter = alter;
        this.rechtshaender = rechtshaender;
        this.groesse = groesse;
        this.initial = initial;
    }
    
    public void setzeVorname(String vorname)
    {    
        this.vorname = vorname;
    }
    
    public String nenneVorname()
    {
        return vorname;
    }
    
    public void setzeAlter(int alter)
    {
        this.alter = alter;
    }
    
    public int nenneAlter()
    {
        return alter;
    }
    
    public void setzeGroesse(double groesse)
    {
        this.groesse = groesse;
    }
    
    public double nenneGroesse()
    {
        return groesse;
    }
    
    public void trink(String farbe)
    {
        if (farbe == "blau")
        {
            groesse += 1.5;
        }
        else
        {
            groesse -= 1.5;
        }
    }
    
    public int schlagBerechnen(int monsterEnergie)
    {
        int wert = 10;
    
        if (monsterEnergie > 30)
        {
            wert = monsterEnergie/2;
        }
        else
        {
            wert = 10;
        }
        return wert;
    }
    
    public void kaempfe(WALDMONSTER monster)
    {
    while (monster.nenneLebensenergie() > 0)
        {
            int energie = monster.nenneLebensenergie();
            int schlag = schlagBerechnen(energie);
            monster.schlagKassieren(schlag);
        }
    }
}
